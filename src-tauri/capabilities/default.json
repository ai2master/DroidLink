{
  "identifier": "default",
  "description": "Default capability for DroidLink main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:allow-open",
    "clipboard-manager:allow-read",
    "clipboard-manager:allow-write",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "process:default",
    "notification:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$TEMP/**" },
        { "path": "$HOME/**" }
      ],
      "deny": [
        { "path": "**/.ssh/**" },
        { "path": "**/.gnupg/**" },
        { "path": "**/id_rsa*" },
        { "path": "**/*.key" },
        { "path": "**/*.pem" }
      ]
    }
  ]
}
